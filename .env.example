# Cloudflare tunnel token (optional, used with --tunnel flag)
TUNNEL_TOKEN=

# RTMP stream key (optional, used with --stream flag)
BIRBER_STREAM_KEY=

# Network camera URL (used when not using --capture flag)
BIRBER_CAPTURE_URL=

# Host IP for WebRTC ICE candidates (your LAN IP, e.g. 192.168.1.97)
# Required for WebRTC to work from local network. Run: hostname -I | awk '{print $1}'
BIRBER_HOST_IP=

# Host port overrides (change if defaults conflict)
# BIRBER_WEB_PORT=8080
# BIRBER_WS_PORT=8765
# BIRBER_WEBRTC_PORT=8889

# Default start.sh flags (used when running ./start.sh with no arguments)
# BIRBER_FLAGS="--gpu --tunnel --capture"

# AMD ROCm: override GPU architecture target (used with --rocm flag)
# Set this for RDNA 3.5 GPUs (Radeon 8060S, etc.) — maps to gfx1100
# HSA_OVERRIDE_GFX_VERSION=11.0.0
